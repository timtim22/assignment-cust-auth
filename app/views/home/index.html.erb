<h1>Custom Authentication & Access Control</h1>

<% if user_signed_in? %>
  <p>Welcome back, <%= current_user.email %>!</p>
  
  <div style="background: #f5f5f5; padding: 15px; border-radius: 5px; margin: 15px 0;">
    <h4>Account Information</h4>
    <p><strong>Age:</strong> <%= current_user.age %> years old</p>
    <% if current_user.minor? %>
      <p><strong>Status:</strong> Minor (under 18)</p>
      <p><strong>Parental Consent:</strong> 
        <% if current_user.parental_consent? %>
          <span style="color: green;">✅ Approved</span>
        <% else %>
          <span style="color: red;">❌ Pending</span>
        <% end %>
      </p>
    <% else %>
      <p><strong>Status:</strong> Adult (18+)</p>
      <p><strong>Access:</strong> <span style="color: green;">✅ Full Access</span></p>
    <% end %>
  </div>
  
  <div style="background: #e3f2fd; padding: 15px; border-radius: 5px; margin: 15px 0;">
    <h4>Quick Actions</h4>
    <div style="display: flex; gap: 10px; flex-wrap: wrap;">
      <%= link_to "🏢 Browse Organizations", organizations_path, 
          style: "background: #1976d2; color: white; padding: 8px 16px; text-decoration: none; border-radius: 4px;" %>
      
      <% if (current_user.administered_organizations.any? || current_user.id == 1) %>
        <%= link_to "🔐 Admin Dashboard", admin_root_path, 
            style: "background: #d32f2f; color: white; padding: 8px 16px; text-decoration: none; border-radius: 4px;" %>
      <% end %>
      
      <% if current_user.organizations.any? %>
        <span style="color: #666;">
          You're a member of <%= pluralize(current_user.organizations.count, 'organization') %>
        </span>
      <% else %>
        <span style="color: #666;">
          Not a member of any organizations yet
        </span>
      <% end %>
    </div>
  </div>
  
  <nav>
    <%= link_to "Sign Out", destroy_user_session_path, method: :delete, data: { confirm: "Are you sure?" } %>
  </nav>
<% else %>
  <p>Please sign in to access the application.</p>
  
  <nav>
    <%= link_to "Sign In", new_user_session_path %> |
    <%= link_to "Sign Up", new_user_registration_path %>
  </nav>
<% end %>
