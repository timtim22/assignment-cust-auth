<div style="max-width: 600px; margin: 0 auto; padding: 20px;">
  <h1>🏗️ Create New Organization</h1>

  <%= form_with model: @organization, local: true do |form| %>
    <% if @organization.errors.any? %>
      <div style="background: #ffebee; border: 1px solid #f44336; padding: 15px; border-radius: 5px; margin-bottom: 20px;">
        <h4 style="color: #d32f2f; margin: 0 0 10px 0;">Please fix the following errors:</h4>
        <ul style="margin: 0; color: #d32f2f;">
          <% @organization.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div style="background: #f5f5f5; padding: 20px; border-radius: 8px;">
      <div style="margin-bottom: 20px;">
        <%= form.label :name, style: "display: block; font-weight: bold; margin-bottom: 5px;" %>
        <%= form.text_field :name, style: "width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px; font-size: 16px;" %>
        <small style="color: #666;">Enter a unique name for your organization</small>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
        <div>
          <%= form.label :min_age, "Minimum Age", style: "display: block; font-weight: bold; margin-bottom: 5px;" %>
          <%= form.number_field :min_age, value: 13, min: 0, max: 120, 
              style: "width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px; font-size: 16px;" %>
          <small style="color: #666;">Minimum age to join</small>
        </div>

        <div>
          <%= form.label :max_age, "Maximum Age", style: "display: block; font-weight: bold; margin-bottom: 5px;" %>
          <%= form.number_field :max_age, value: 25, min: 0, max: 120,
              style: "width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px; font-size: 16px;" %>
          <small style="color: #666;">Maximum age to join</small>
        </div>
      </div>

      <div style="background: #e3f2fd; padding: 15px; border-radius: 5px; margin-bottom: 20px;">
        <h4 style="margin: 0 0 10px 0; color: #1976d2;">📋 Organization Details</h4>
        <p style="margin: 0; color: #666; font-size: 14px;">
          • You will automatically become an <strong>admin</strong> of this organization<br>
          • Age restrictions will be enforced for all members<br>
          • Only users with parental consent (if minors) can join<br>
          • You can manage members and roles after creation
        </p>
      </div>

      <div style="text-align: center;">
        <%= form.submit "Create Organization", 
            style: "background: #4caf50; color: white; padding: 12px 30px; border: none; border-radius: 5px; font-size: 16px; cursor: pointer; margin-right: 10px;" %>
        <%= link_to "Cancel", organizations_path, 
            style: "background: #ccc; color: #666; padding: 12px 30px; text-decoration: none; border-radius: 5px; font-size: 16px;" %>
      </div>
    </div>
  <% end %>
</div>
