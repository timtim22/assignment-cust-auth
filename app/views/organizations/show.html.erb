<div style="max-width: 800px; margin: 0 auto; padding: 20px;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
    <h1>🏢 <%= @organization.name %></h1>
    
    <div>
      <% if @is_member %>
        <% if @user_role == 'admin' %>
          <span style="background: #ff9800; color: white; padding: 8px 16px; border-radius: 4px; margin-right: 10px;">
            👑 Admin
          </span>
        <% else %>
          <span style="background: #4caf50; color: white; padding: 8px 16px; border-radius: 4px; margin-right: 10px;">
            ✅ Member
          </span>
        <% end %>
        <%= link_to "Leave Organization", leave_organization_path(@organization), method: :delete, 
            data: { confirm: "Are you sure you want to leave #{@organization.name}?" },
            style: "background: #d32f2f; color: white; padding: 8px 16px; text-decoration: none; border-radius: 4px;" %>
      <% elsif @can_join %>
        <%= link_to "Join Organization", join_organization_path(@organization), method: :post,
            style: "background: #4caf50; color: white; padding: 10px 20px; text-decoration: none; border-radius: 4px;" %>
      <% end %>
    </div>
  </div>

  <!-- Organization Info -->
  <div style="background: #f5f5f5; padding: 20px; border-radius: 8px; margin-bottom: 30px;">
    <h3>📋 Organization Details</h3>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px;">
      <div>
        <strong>Age Requirements:</strong><br>
        <span style="font-size: 18px; color: #1976d2;"><%= @organization.min_age %> - <%= @organization.max_age %> years old</span>
      </div>
      <div>
        <strong>Total Members:</strong><br>
        <span style="font-size: 18px; color: #4caf50;"><%= @organization.users.count %> members</span>
      </div>
      <div>
        <strong>Your Eligibility:</strong><br>
        <% if @organization.available_for_user?(current_user) %>
          <span style="color: #4caf50; font-weight: bold;">✅ Eligible</span>
        <% else %>
          <span style="color: #f44336; font-weight: bold;">❌ Age Restricted</span>
        <% end %>
      </div>
    </div>
  </div>

  <!-- User Status -->
  <% unless @is_member %>
    <div style="background: #e3f2fd; padding: 20px; border-radius: 8px; margin-bottom: 30px;">
      <h3>🎯 Membership Status</h3>
      <% if !@organization.available_for_user?(current_user) %>
        <div style="background: #ffebee; padding: 15px; border-radius: 5px; border-left: 4px solid #f44336;">
          <strong>Age Restriction:</strong> You are <%= current_user.age %> years old, but this organization is for ages <%= @organization.min_age %>-<%= @organization.max_age %>.
        </div>
      <% elsif !current_user.has_full_access? %>
        <div style="background: #fff3e0; padding: 15px; border-radius: 5px; border-left: 4px solid #ff9800;">
          <strong>Parental Consent Required:</strong> You need parental consent approval before you can join organizations.
          <%= link_to "Check Consent Status", parental_consent_pending_path, style: "color: #1976d2;" %>
        </div>
      <% else %>
        <div style="background: #e8f5e8; padding: 15px; border-radius: 5px; border-left: 4px solid #4caf50;">
          <strong>Ready to Join:</strong> You meet all requirements and can join this organization!
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- Members List -->
  <div style="background: #f9f9f9; padding: 20px; border-radius: 8px; margin-bottom: 30px;">
    <h3>👥 Members</h3>
    
    <!-- Admins -->
    <% if @organization.admins.any? %>
      <div style="margin-bottom: 20px;">
        <h4 style="color: #ff9800; margin-bottom: 10px;">👑 Administrators</h4>
        <div style="display: grid; gap: 10px;">
          <% @organization.admins.each do |admin| %>
            <div style="background: white; padding: 10px; border-radius: 5px; border-left: 4px solid #ff9800;">
              <strong><%= admin.email %></strong>
              <span style="color: #666; margin-left: 10px;">Age: <%= admin.age %></span>
              <% if admin == current_user %>
                <span style="background: #1976d2; color: white; padding: 2px 6px; border-radius: 3px; font-size: 10px; margin-left: 5px;">YOU</span>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Regular Members -->
    <% if @organization.members.any? %>
      <div>
        <h4 style="color: #4caf50; margin-bottom: 10px;">👤 Members</h4>
        <div style="display: grid; gap: 10px;">
          <% @organization.members.each do |member| %>
            <div style="background: white; padding: 10px; border-radius: 5px; border-left: 4px solid #4caf50;">
              <strong><%= member.email %></strong>
              <span style="color: #666; margin-left: 10px;">Age: <%= member.age %></span>
              <% if member == current_user %>
                <span style="background: #1976d2; color: white; padding: 2px 6px; border-radius: 3px; font-size: 10px; margin-left: 5px;">YOU</span>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @organization.users.empty? %>
      <p style="color: #666; text-align: center; padding: 20px;">
        No members yet. Be the first to join!
      </p>
    <% end %>
  </div>

  <!-- Back Navigation -->
  <div style="text-align: center;">
    <%= link_to "← Back to Organizations", organizations_path, 
        style: "background: #1976d2; color: white; padding: 10px 20px; text-decoration: none; border-radius: 4px;" %>
  </div>
</div>
